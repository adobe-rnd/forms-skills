{
  "id": "apply-rule-patch-add",
  "description": "When fd:rules does not exist, generates an add op inserting a full fd:rules node",
  "script": "forms-content-update/scripts/apply-rule-patch.bundle.js",
  "args": {
    "--merged-rule-file": "fixture:merged-rule-visible.json",
    "--find-field-result-file": "fixture:ff-result-rules-not-found.json",
    "--field-pointer": "/items/0/items/0"
  },
  "expectedExitCode": 0,
  "expectedOutput": [
    {
      "op": "add",
      "path": "/items/0/items/0/items/0",
      "value": {
        "id": "fd:rules",
        "componentType": "fd:rules"
      }
    }
  ]
}
