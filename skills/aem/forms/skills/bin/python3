#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# AEM Forms Skills — Python wrapper with lazy venv bootstrap
#
# Thin wrapper that ensures the plugin's virtual environment exists before
# running any Python command. On first invocation it silently runs setup.sh
# to create .venv and install all dependencies. Subsequent calls go straight
# through with no overhead.
#
# SKILL.md files reference this as:
#   "${CLAUDE_PLUGIN_ROOT}/bin/python3" "${CLAUDE_PLUGIN_ROOT}/scripts/some_tool/cli.py" ...
# ─────────────────────────────────────────────────────────────────────────────
set -e

PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
VENV_PYTHON="$PLUGIN_ROOT/.venv/bin/python3"

# Bootstrap the venv if it doesn't exist yet
if [ ! -x "$VENV_PYTHON" ]; then
  echo "⏳ First run — setting up AEM Forms Skills environment…" >&2
  "$PLUGIN_ROOT/setup.sh" >&2
  echo "" >&2

  # Verify setup succeeded
  if [ ! -x "$VENV_PYTHON" ]; then
    echo "❌ Setup failed — .venv/bin/python3 not found after running setup.sh" >&2
    exit 1
  fi
fi

exec "$VENV_PYTHON" "$@"
